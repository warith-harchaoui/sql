# .env.example — configuration de la démo text2sql.
# --------------------------------------------------
# Copie ce fichier en `.env` puis ajuste si besoin :
#   cp .env.example .env
# `.env` est gitignoré (cf. .gitignore) — n'y mets jamais de secret réel.
#
# La démo fonctionne SANS `.env` : toutes ces valeurs ont des défauts codés en
# dur qui correspondent à une installation Ollama locale standard. Ce fichier
# sert à surcharger un défaut (autre hôte Ollama, autre modèle, etc.).

# --- Serveur Ollama ---------------------------------------------------------
# REQUIS pour les LLM. URL de base du serveur Ollama local.
# Comment l'obtenir : installe Ollama (https://ollama.com) puis `ollama serve`.
# Format attendu : http://HOTE:PORT (par défaut le port 11434).
OLLAMA_URL=http://localhost:11434

# --- Modèles (tags Ollama) --------------------------------------------------
# OPTIONNEL. Modèle de génération SQL (approches QwenCoder brut / LangChain / Vanna).
# Comment l'obtenir : `ollama pull qwen2.5-coder`.
# Un modèle de CODE est recommandé (meilleur en SQL qu'un modèle généraliste).
MODEL_SQL=qwen2.5-coder:latest

# OPTIONNEL. Modèle qui CHOISIT la figure (spec Vega-Lite).
# Comment l'obtenir : `ollama pull gemma3` (ou une variante gemma déjà tirée).
# La variante `-mlx` est optimisée Apple Silicon.
MODEL_FIGURE=gemma4:e4b-mlx

# OPTIONNEL. Modèle d'embeddings pour le RAG de Vanna.
# Comment l'obtenir : `ollama pull nomic-embed-text`.
MODEL_EMBED=nomic-embed-text:latest

# --- Base de données --------------------------------------------------------
# OPTIONNEL. Chemin du fichier SQLite généré par `python -m backend.build_db`.
# Laisse vide pour utiliser le défaut `data/institut.db`.
# DB_PATH=data/institut.db
